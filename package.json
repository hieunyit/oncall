    "db:push": "prisma db push",
    "db:generate": "prisma generate",
    "db:studio": "prisma studio",
    "workers": "ts-node --esm workers/index.ts",
    "workers:dev": "tsx workers/index.ts",
    "db:seed": "tsx prisma/seed.ts",
    "make-admin": "tsx scripts/make-admin.ts",
    "cleanup:stale:preview": "tsx scripts/cleanup-stale-policy-data.ts",
    "cleanup:stale:execute": "tsx scripts/cleanup-stale-policy-data.ts --execute",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  },
  "dependencies": {
