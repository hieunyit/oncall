    "@sentry/nextjs": "^10.50.0",
    "@types/ioredis": "^4.28.10",
    "@types/pg": "^8.20.0",
    "bullmq": "^5.76.2",
    "croner": "^10.0.1",
    "date-fns": "^4.1.0",
    "ioredis": "^5.10.1",
    "next": "16.2.4",
    "next-auth": "^5.0.0-beta.31",
    "pg": "^8.20.0",
    "prisma": "^7.8.0",
    "react": "19.2.4",
    "react-dom": "19.2.4",
    "resend": "^6.12.2",
    "zod": "^4.3.6"
  },
  "devDependencies": {
