generator client {
  provider      = "prisma-client"
  output        = "../app/generated/prisma"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
}

// ─── Enums ────────────────────────────────────────────────────────────────────

enum SystemRole {
  ADMIN
  USER
}

enum TeamRole {
  MANAGER
  MEMBER
}

enum ChannelType {
  EMAIL
  TEAMS
  TELEGRAM
}

enum ShiftStatus {
  DRAFT
  PUBLISHED
  ACTIVE
  COMPLETED
  CANCELLED
}

enum ShiftSource {
  AUTOGENERATED
  MANUAL
  SWAP
  OVERRIDE
}

enum CadenceKind {
  DAILY
  WEEKLY
  CUSTOM_CRON
}

enum ConfirmationStatus {
  PENDING
  CONFIRMED
  DECLINED
  EXPIRED
}

enum SwapStatus {
  REQUESTED
  ACCEPTED_BY_TARGET
  APPROVED
  REJECTED
  CANCELLED
  EXPIRED
}

enum DeliveryStatus {
  QUEUED
  SENT
  DELIVERED
  FAILED
  RETRYING
  CANCELLED
}

enum EscalationTarget {
  PRIMARY
  BACKUP
  MANAGER
  TEAM_CHANNEL
}

enum BatchStatus {
  PUBLISHED
  ROLLED_BACK
  PARTIAL
}

enum NotificationUrgency {
  DEFAULT
  IMPORTANT
}

enum AlertStatus {
  FIRING
  ACKNOWLEDGED
  RESOLVED
}

enum IntegrationType {
  GENERIC_WEBHOOK
  PROMETHEUS
  GRAFANA
}

// ─── Auth.js tables ──────────────────────────────────────────────────────────

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

// ─── Core domain models ───────────────────────────────────────────────────────

model User {
  id                  String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email               String     @unique
  fullName            String     @map("full_name")
  keycloakId          String?    @unique @map("keycloak_id")
  telegramChatId      BigInt?    @map("telegram_chat_id")
  teamsUserId         String?    @map("teams_user_id")
  teamsConversationId String?    @map("teams_conversation_id")
  phone               String?    @map("phone")
  systemRole          SystemRole @default(USER) @map("system_role")
  timezone            String     @default("Asia/Ho_Chi_Minh")
  isActive            Boolean    @default(true) @map("is_active")
  createdAt           DateTime   @default(now()) @map("created_at")
  updatedAt           DateTime   @updatedAt @map("updated_at")

  // Auth.js relations
  accounts Account[]
  sessions Session[]

  // Domain relations
  teamMembers            TeamMember[]
  shiftsAsAssignee       Shift[]              @relation("ShiftAssignee")
  shiftsAsBackup         Shift[]              @relation("ShiftBackup")
  shiftConfirmations     ShiftConfirmation[]
  swapRequestsFrom       SwapRequest[]        @relation("SwapRequester")
  swapRequestsTarget     SwapRequest[]        @relation("SwapTarget")
  auditLogs              AuditLog[]
  notificationRules      UserNotificationRule[]
  acknowledgedAlerts     Alert[]              @relation("AlertAcknowledger")

  @@map("users")
}

model Team {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name         String   @unique
  description  String?
  slackChannel String?  @map("slack_channel")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  members              TeamMember[]
  rotationPolicies     RotationPolicy[]
  notificationChannels TeamNotificationChannel[]
  escalationPolicies   EscalationPolicy[]
  alertIntegrations    AlertIntegration[]

  @@map("teams")
}

model TeamMember {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId   String   @map("team_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  role     TeamRole @default(MEMBER)
  order    Int      @default(0)
  joinedAt DateTime @default(now()) @map("joined_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@map("team_members")
}

model RotationPolicy {
  id                    String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId                String      @map("team_id") @db.Uuid
  escalationPolicyId    String?     @map("escalation_policy_id") @db.Uuid
  name                  String
  cadence               CadenceKind
  cronExpression        String?     @map("cron_expression")
  shiftDurationHours    Int         @map("shift_duration_hours")
  handoverOffsetMinutes Int         @default(0) @map("handover_offset_minutes")
  confirmationDueHours  Int         @default(24) @map("confirmation_due_hours")
  reminderLeadHours     Int[]       @default([24, 2]) @map("reminder_lead_hours")
  maxGenerateWeeks      Int         @default(4) @map("max_generate_weeks")
  isActive              Boolean     @default(true) @map("is_active")
  createdAt             DateTime    @default(now()) @map("created_at")
  updatedAt             DateTime    @updatedAt @map("updated_at")

  team              Team              @relation(fields: [teamId], references: [id], onDelete: Cascade)
  escalationPolicy  EscalationPolicy? @relation(fields: [escalationPolicyId], references: [id])
  scheduleBatches   ScheduleBatch[]
  shifts            Shift[]

  @@map("rotation_policies")
}

model ScheduleBatch {
  id             String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId       String      @map("policy_id") @db.Uuid
  publishedBy    String      @map("published_by") @db.Uuid
  rangeStart     DateTime    @map("range_start")
  rangeEnd       DateTime    @map("range_end")
  status         BatchStatus @default(PUBLISHED)
  idempotencyKey String      @unique @map("idempotency_key")
  createdAt      DateTime    @default(now()) @map("created_at")

  policy RotationPolicy @relation(fields: [policyId], references: [id])
  shifts Shift[]

  @@map("schedule_batches")
}

model Shift {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  policyId            String      @map("policy_id") @db.Uuid
  batchId             String?     @map("batch_id") @db.Uuid
  assigneeId          String      @map("assignee_id") @db.Uuid
  backupId            String?     @map("backup_id") @db.Uuid
  overrideForShiftId  String?     @map("override_for_shift_id") @db.Uuid
  startsAt            DateTime    @map("starts_at")
  endsAt              DateTime    @map("ends_at")
  status              ShiftStatus @default(DRAFT)
  source              ShiftSource @default(AUTOGENERATED)
  version             Int         @default(0)
  notes               String?
  createdAt           DateTime    @default(now()) @map("created_at")
  updatedAt           DateTime    @updatedAt @map("updated_at")

  policy           RotationPolicy     @relation(fields: [policyId], references: [id])
  batch            ScheduleBatch?     @relation(fields: [batchId], references: [id])
  assignee         User               @relation("ShiftAssignee", fields: [assigneeId], references: [id])
  backup           User?              @relation("ShiftBackup", fields: [backupId], references: [id])
  overrideForShift Shift?             @relation("ShiftOverride", fields: [overrideForShiftId], references: [id])
  overrides        Shift[]            @relation("ShiftOverride")
  confirmation     ShiftConfirmation?
  swapRequestsAsOriginal SwapRequest[] @relation("SwapOriginalShift")
  swapRequestsAsTarget   SwapRequest[] @relation("SwapTargetShift")

  @@index([policyId, startsAt, endsAt])
  @@index([assigneeId, startsAt])
  @@index([status])
  @@map("shifts")
}

model ShiftConfirmation {
  id          String             @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId     String             @unique @map("shift_id") @db.Uuid
  userId      String             @map("user_id") @db.Uuid
  status      ConfirmationStatus @default(PENDING)
  dueAt       DateTime           @map("due_at")
  respondedAt DateTime?          @map("responded_at")
  token       String             @unique @default(dbgenerated("encode(gen_random_bytes(32), 'hex')"))
  createdAt   DateTime           @default(now()) @map("created_at")
  updatedAt   DateTime           @updatedAt @map("updated_at")

  shift Shift @relation(fields: [shiftId], references: [id], onDelete: Cascade)
  user  User  @relation(fields: [userId], references: [id])

  @@map("shift_confirmations")
}

model SwapRequest {
  id              String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  requesterId     String     @map("requester_id") @db.Uuid
  targetUserId    String     @map("target_user_id") @db.Uuid
  originalShiftId String     @map("original_shift_id") @db.Uuid
  targetShiftId   String?    @map("target_shift_id") @db.Uuid
  status          SwapStatus @default(REQUESTED)
  requesterNote   String?    @map("requester_note")
  targetNote      String?    @map("target_note")
  managerNote     String?    @map("manager_note")
  expiresAt       DateTime   @map("expires_at")
  idempotencyKey  String?    @unique @map("idempotency_key")
  version         Int        @default(0)
  createdAt       DateTime   @default(now()) @map("created_at")
  updatedAt       DateTime   @updatedAt @map("updated_at")

  requester     User   @relation("SwapRequester", fields: [requesterId], references: [id])
  targetUser    User   @relation("SwapTarget", fields: [targetUserId], references: [id])
  originalShift Shift  @relation("SwapOriginalShift", fields: [originalShiftId], references: [id])
  targetShift   Shift? @relation("SwapTargetShift", fields: [targetShiftId], references: [id])

  @@index([requesterId, status])
  @@index([targetUserId, status])
  @@map("swap_requests")
}

model TeamNotificationChannel {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId     String      @map("team_id") @db.Uuid
  type       ChannelType
  name       String
  configJson Json        @map("config_json")
  isActive   Boolean     @default(true) @map("is_active")
  createdAt  DateTime    @default(now()) @map("created_at")
  updatedAt  DateTime    @updatedAt @map("updated_at")

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@unique([teamId, type, name])
  @@map("team_notification_channels")
}

model NotificationMessage {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  shiftId       String?     @map("shift_id") @db.Uuid
  swapRequestId String?     @map("swap_request_id") @db.Uuid
  recipientId   String      @map("recipient_id") @db.Uuid
  channelType   ChannelType @map("channel_type")
  eventType     String      @map("event_type")
  templateId    String      @map("template_id")
  payloadJson   Json        @map("payload_json")
  createdAt     DateTime    @default(now()) @map("created_at")

  deliveries NotificationDelivery[]

  @@index([shiftId])
  @@index([recipientId, createdAt])
  @@map("notification_messages")
}

model NotificationDelivery {
  id            String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  messageId     String         @map("message_id") @db.Uuid
  channelType   ChannelType    @map("channel_type")
  status        DeliveryStatus @default(QUEUED)
  attemptCount  Int            @default(0) @map("attempt_count")
  lastAttemptAt DateTime?      @map("last_attempt_at")
  externalId    String?        @map("external_id")
  errorJson     Json?          @map("error_json")
  createdAt     DateTime       @default(now()) @map("created_at")
  updatedAt     DateTime       @updatedAt @map("updated_at")

  message NotificationMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@index([status, channelType])
  @@map("notification_deliveries")
}

model EscalationPolicy {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId      String   @map("team_id") @db.Uuid
  name        String
  description String?
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  team             Team             @relation(fields: [teamId], references: [id], onDelete: Cascade)
  rules            EscalationRule[]
  rotationPolicies RotationPolicy[]

  @@map("escalation_policies")
}

model EscalationRule {
  id               String           @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  escalationPolicyId String         @map("escalation_policy_id") @db.Uuid
  stepOrder        Int              @map("step_order")
  target           EscalationTarget
  delayMinutes     Int              @map("delay_minutes")
  channelType      ChannelType      @map("channel_type")
  isActive         Boolean          @default(true) @map("is_active")
  createdAt        DateTime         @default(now()) @map("created_at")

  escalationPolicy EscalationPolicy @relation(fields: [escalationPolicyId], references: [id], onDelete: Cascade)

  @@unique([escalationPolicyId, stepOrder])
  @@map("escalation_rules")
}

model UserNotificationRule {
  id           String              @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  userId       String              @map("user_id") @db.Uuid
  urgency      NotificationUrgency @default(DEFAULT)
  stepOrder    Int                 @map("step_order")
  channelType  ChannelType         @map("channel_type")
  delayMinutes Int                 @default(0) @map("delay_minutes")
  isActive     Boolean             @default(true) @map("is_active")
  createdAt    DateTime            @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, urgency, stepOrder])
  @@map("user_notification_rules")
}

model AuditLog {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  actorId    String?  @map("actor_id") @db.Uuid
  entityType String   @map("entity_type")
  entityId   String   @map("entity_id")
  action     String
  oldValue   Json?    @map("old_value")
  newValue   Json?    @map("new_value")
  ipAddress  String?  @map("ip_address")
  userAgent  String?  @map("user_agent")
  createdAt  DateTime @default(now()) @map("created_at")

  actor User? @relation(fields: [actorId], references: [id], onDelete: SetNull)

  @@index([entityType, entityId])
  @@index([actorId, createdAt])
  @@map("audit_logs")
}

model AlertIntegration {
  id        String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  teamId    String          @map("team_id") @db.Uuid
  name      String
  type      IntegrationType @default(GENERIC_WEBHOOK)
  token     String          @unique @default(dbgenerated("encode(gen_random_bytes(24), 'hex')"))
  isActive  Boolean         @default(true) @map("is_active")
  createdAt DateTime        @default(now()) @map("created_at")
  updatedAt DateTime        @updatedAt @map("updated_at")

  team   Team    @relation(fields: [teamId], references: [id], onDelete: Cascade)
  alerts Alert[]

  @@index([teamId])
  @@map("alert_integrations")
}

model Alert {
  id               String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  integrationId    String      @map("integration_id") @db.Uuid
  title            String
  message          String?
  severity         String?
  status           AlertStatus @default(FIRING)
  sourceRef        String?     @map("source_ref")
  payloadJson      Json        @map("payload_json")
  triggeredAt      DateTime    @default(now()) @map("triggered_at")
  acknowledgedById String?     @map("acknowledged_by") @db.Uuid
  acknowledgedAt   DateTime?   @map("acknowledged_at")
  resolvedAt       DateTime?   @map("resolved_at")
  createdAt        DateTime    @default(now()) @map("created_at")
  updatedAt        DateTime    @updatedAt @map("updated_at")

  integration  AlertIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)
  acknowledger User?            @relation("AlertAcknowledger", fields: [acknowledgedById], references: [id])

  @@index([integrationId, triggeredAt])
  @@index([status])
  @@map("alerts")
}
